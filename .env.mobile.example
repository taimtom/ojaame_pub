# Mobile production build — copy to .env.mobile before `npm run build:mobile`
# Native WebView cannot use the Vite dev proxy; API URL must be absolute.
#
# Commands:
#   cp .env.mobile.example .env.mobile
#   npm run build:mobile
#   npx cap sync android
#   npm run mobile:android   # build + sync + open Android Studio

VITE_SERVER_URL=https://api.ojaa.me
VITE_BASE_PATH=
