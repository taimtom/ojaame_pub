# =============================================================================
# Frontend Environment Variables (for Vercel)
# =============================================================================
# Add these in Vercel Dashboard → Settings → Environment Variables
# Only variables starting with VITE_ are exposed to the client
# =============================================================================

# =============================================================================
# [REQUIRED] BACKEND API URL
# =============================================================================
# Your EC2 backend URL
VITE_SERVER_URL=http://44.221.61.21:8004
# Or with domain: https://api.yourdomain.com

# =============================================================================
# OPTIONAL: EXTERNAL SERVICES
# =============================================================================
# Google OAuth
VITE_GOOGLE_CLIENT_ID=

# Mapbox (for maps)
VITE_MAPBOX_API_KEY=

# Firebase (if using Firebase auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APPID=
VITE_FIREBASE_MEASUREMENT_ID=

# Auth0 (if using Auth0)
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CALLBACK_URL=

# Supabase (if using Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AWS Amplify (if using Amplify)
VITE_AWS_AMPLIFY_USER_POOL_ID=
VITE_AWS_AMPLIFY_USER_POOL_WEB_CLIENT_ID=
VITE_AWS_AMPLIFY_REGION=

# Jumia Integration
VITE_JUMIA_API_KEY=
VITE_JUMIA_USER_ID=
VITE_JUMIA_ENDPOINT=

# =============================================================================
# SUMMARY OF REQUIRED VARIABLES
# =============================================================================
# 1. VITE_SERVER_URL - Backend API URL (REQUIRED)
# =============================================================================
